# Rust build output
/target
**/*.rs.bk

# Runtime state and local artifacts (never commit)
.notion-sync/
state.db
*.db
*.db-wal
*.db-shm

# Secrets and personal config (ship config.example.toml instead)
*.env
config.toml

# Nix / editor / OS noise
result
.direnv/
.DS_Store

# NOTE: Cargo.lock is intentionally committed (this is a binary; the flake's
# cargoLock.lockFile = ./Cargo.lock needs it for reproducible builds).
#
# If config.toml was already committed before this rule existed, untrack it
# (this keeps your local copy) and commit the removal:
#     git rm --cached config.toml && git commit -m "chore: stop tracking config.toml"
